{
  "name": "gerenciador-festas",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "api": "yarn workspace gf-servidor dev",
    "web": "yarn workspace gf-web dev",
    "build": "yarn workspace gf-web build",
    "deploy": "yarn workspace gf-web deploy",
    "format": "yarn workspaces foreach -A -p run format",
    "lint": "yarn workspaces foreach -A -p run lint"
  },
  "resolutions": {
    "@types/express": "4.17.25"
  }
}
